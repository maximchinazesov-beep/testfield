local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local function triggerAntiStealer(reason)
    if LocalPlayer then
        LocalPlayer:Kick("Security Alert: " .. reason .. "\nGet official script from Discord.")
    end
    task.wait(9e9)
    while true do end
end

local env = getgenv and getgenv() or _G
local environmentSafe = true
local detectionReason = ""

-- =========================================================
-- V3: Метод ловушки через ошибку (Traceback Analysis)
-- =========================================================
local function testViaErrorTrap(func, funcName)
    local trace = ""
    
    -- Пытаемся выполнить функцию с заведомо неверным аргументом
    -- Это заставит внутреннюю C-логику экзекьютора "выплюнуть" ошибку.
    local success, err = xpcall(function()
        if string.find(funcName:lower(), "request") then
            func(123) -- request ожидает таблицу, а мы даем число
        elseif string.find(funcName:lower(), "http") then
            func(game, 123) -- HttpGet ожидает строку
        else
            func()
        end
    end, function(msg)
        -- Ловим ошибку и записываем весь стек вызовов
        trace = debug.traceback(msg)
        return msg
    end)

    -- Если ошибки почему-то нет (функция ничего не вернула на мусорный аргумент),
    -- значит хук "проглотил" аргумент и даже не передал его в оригинал.
    if success then
        return true, "Error trap swallowed by hook on " .. funcName
    end

    -- Анализируем стек. 
    -- Если функция оригинальная (C++), ошибка идет напрямую.
    -- Если висит Lua-хук, в стеке засветятся строки типа "[string", "chunk" или ".lua"
    -- перед тем, как вызов дойдет до ядра экзекьютора.
    if string.find(trace, "%[string") or string.find(trace, "%.lua") or string.find(trace, "chunk") then
        -- Исключаем наш собственный скрипт из проверки (если мы тестируем внутри Studio/одного файла)
        -- Но в экзекьюторе наличие "[string" в функции request — это 100% стиллер.
        return true, "Hidden Lua traceback detected on " .. funcName
    end
    
    return false, ""
end

-- =========================================================
-- Проверка количества Upvalues
-- =========================================================
-- hookfunction часто сохраняет оригинальную функцию как upvalue (свободную переменную).
-- Чистые C-функции экзекьютора обычно не имеют upvalues.
local function checkUpvalues(func, funcName)
    if type(debug) == "table" and type(debug.getupvalues) == "function" then
        local success, upvalues = pcall(debug.getupvalues, func)
        if success and type(upvalues) == "table" then
            -- Если у базовой функции внезапно появились внутренние переменные
            local count = 0
            for k, v in pairs(upvalues) do count = count + 1 end
            if count > 0 then
                return true, "Unexpected upvalues ("..count..") found on " .. funcName
            end
        end
    end
    return false, ""
end

-- Собираем цели
local targetsToInspect = {
    ["request"] = env.request or request,
    ["http_request"] = env.http_request or http_request,
    ["HttpGet"] = game.HttpGet
}

print("[Anti-Stealer V3] Running deep trace analysis...")

for name, func in pairs(targetsToInspect) do
    if type(func) == "function" then
        -- 1. Проверка через стек ошибок (самая мощная)
        local isCompromised, reason = testViaErrorTrap(func, name)
        if isCompromised then
            environmentSafe = false
            detectionReason = reason
            break
        end

        -- 2. Проверка "внутренностей" (Upvalues)
        isCompromised, reason = checkUpvalues(func, name)
        if isCompromised then
            environmentSafe = false
            detectionReason = reason
            break
        end
    end
end

-- Итог
if not environmentSafe then
    warn("[Anti-Stealer V3] " .. detectionReason)
    triggerAntiStealer(detectionReason)
    return 
end

print("All safe, loading...")
