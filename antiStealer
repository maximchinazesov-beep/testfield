-- maded by rio on 05.05 for protecting dusk & shine script from scammers
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local function kickPlayer(reason)
    if LocalPlayer then
        LocalPlayer:Kick("Security Alert: " .. reason .. "\nGet official script from Discord.")
    end
    task.wait(9e9)
    while true do end
end

-- Твой официальный вебхук или домен (чтобы скрипт не забанил сам себя)
local SAFE_URLS = {
    "duskandshine.xyz",
    "maximchinazesov-beep", -- твой гитхаб из лоадера
    -- "discord.com/api/webhooks/ТВОЙ_ОФИЦИАЛЬНЫЙ_ВЕБХУК" 
}

local environmentSafe = true
local detectReason = ""

-- =========================================================
-- Сканирование Garbage Collector (Памяти)
-- =========================================================
-- Любой скрипт, загруженный через loadstring, или любой вебхук, 
-- отправленный через request, оседает в памяти Lua в виде строк, 
-- пока сборщик мусора их не удалит (а удаляет он их не сразу).
local function scanMemory()
    if type(getgc) ~= "function" then
        return false, "Executor doesn't support getgc (memory scan)"
    end

    print("[Anti-Stealer] Scanning memory...")
    
    -- Получаем все объекты в памяти (строки, таблицы, функции)
    local gc = getgc(true)
    for i = 1, #gc do
        local v = gc[i]
        
        -- Ищем подозрительные СТРОКИ в памяти
        if type(v) == "string" then
            -- 1. Поиск чужих Discord вебхуков
            if string.find(v, "discord%.com/api/webhooks") then
                local isSafe = false
                for _, safeUrl in ipairs(SAFE_URLS) do
                    if string.find(v, safeUrl) then
                        isSafe = true
                        break
                    end
                end
                
                if not isSafe then
                    return true, "Foreign webhook found in memory!"
                end
            end
            
            -- 2. Поиск типичных сигнатур стиллеров, которые они прячут в коде
            local suspiciousStrings = {
                "Tsuo", "Stealer", "W-e-b-h-o-o-k", "GetGlobalUser", "Token_Grabber"
            }
            for _, sig in ipairs(suspiciousStrings) do
                if string.find(v, sig) then
                    return true, "Malicious signature found in memory: " .. sig
                end
            end
        end
    end
    
    return false, ""
end

-- =========================================================
-- Проверка Registry (Реестра Lua)
-- =========================================================
-- Лоадеры и стиллеры часто сохраняют свои потоки (threads) или функции в реестр.
local function scanRegistry()
    if type(getreg) ~= "function" then return false, "" end
    
    local reg = getreg()
    for k, v in pairs(reg) do
        if type(v) == "string" and string.find(v, "discord%.com/api/webhooks") then
            -- Аналогичная проверка на чужие вебхуки в реестре
             local isSafe = false
             for _, safeUrl in ipairs(SAFE_URLS) do
                 if string.find(v, safeUrl) then isSafe = true; break end
             end
             if not isSafe then
                 return true, "Foreign webhook found in Registry!"
             end
        end
    end
    return false, ""
end

-- =========================================================
-- Запуск проверок
-- =========================================================

-- 1. Проверяем память
local isCompromised, reason = scanMemory()
if isCompromised then
    environmentSafe = false
    detectReason = reason
end

-- 2. Проверяем реестр
if environmentSafe then
    isCompromised, reason = scanRegistry()
    if isCompromised then
        environmentSafe = false
        detectReason = reason
    end
end

-- 3. Базовая проверка чистоты глобальной среды (поиск левых переменных)
if environmentSafe then
    local env = getgenv and getgenv() or _G
    for k, _ in pairs(env) do
        if type(k) == "string" and (string.match(k:lower(), "stealer") or string.match(k:lower(), "webhook")) then
            environmentSafe = false
            detectReason = "Suspicious global variable: " .. k
            break
        end
    end
end

if not environmentSafe then
    warn("[Anti-Stealer] " .. detectReason)
    kickPlayer(detectReason)
    return
end

print("All safe, loading.")
